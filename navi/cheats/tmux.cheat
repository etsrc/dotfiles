% tmux

# Kill the current session you are attached to
tmux kill-session

# Kill a specific session by nam
tmux kill-session -t <session>

# Kill every single session
tmux kill-server

# Start new Session
tmux new-session -t <session_name>

# Move window to the left
tmux swap-window -t -1

# Move window to the right
tmux swap-window -t +1

